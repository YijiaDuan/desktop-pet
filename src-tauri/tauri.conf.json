{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Pet",
  "version": "0.1.0",
  "identifier": "net.yijia.desktoppet",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Desktop Pet",
        "width": 220,
        "height": 220,
        "x": 1200,
        "y": 700,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "fullscreen": false,
        "minimizable": false,
        "maximizable": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "wix": {
        "language": ["en-US", "zh-CN"]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese"]
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true
    },
    "category": "Entertainment",
    "shortDescription": "Cozy desktop companions.",
    "longDescription": "Desktop Pet is a small companion that lives on your screen. Pick a pet (a goose for now, more on the way), and it'll breathe, blink, get curious about your cursor, and sleep when you ignore it."
  }
}
